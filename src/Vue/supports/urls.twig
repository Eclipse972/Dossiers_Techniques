{#
    URLs centralisées des ressources d'un support.
    Variable requise : dossier (nom du dossier du support)

	UTILISATION
	1- Dans les template des supports ajouter: {% include 'supports/urls.twig' %}
	2- La variable dossier étant passée par le contrôleur, toutes les URLs sont construites automatiquement.
	Il n'y aura rien à changer si la structure des dossiers évolue.

	EXEMPLE :
	{% include 'supports/urls.twig' %}

	<img src="{{ url_image }}/photo.png" />
#}

{% set url_image = '/supports/' ~ dossier ~ '/images' %}
{% set url_piece = '/supports/' ~ dossier ~ '/pieces' %}
{% set url_assemblage = '/supports/' ~ dossier ~ '/assemblages' %}
{% set url_dessin = '/supports/' ~ dossier ~ '/dessins' %}