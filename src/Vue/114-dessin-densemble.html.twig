{#
	Page de dessin d'ensemble
	Par convention :
		- image: dessin-{{ dossier }}.png
		- fichier: {{ dossier }}.EDRW
	Où dossier est le nom du support en keba-case (nom du dossier sur le disque ainsi que l'URL de base du support).
	Exemple: bouton-poussoir
#}

{% extends '11-base-avec-nav.html.twig' %}

{% block contenu %}
<h1>Dessin d'ensemble</h1>
<a href="/supports/{{ dossier }}/fichiers/{{ dossier }}.EDRW" title="Télécharger le dessin d'ensemble {{ du }}{{ support }}">
    <img src="/supports/{{ dossier }}/images/dessin-{{ support }}.png" alt="Dessin d'ensemble {{ du }}{{ support }}" class="association">
</a>
{% endblock %}