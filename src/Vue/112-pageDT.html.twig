{#
	Page de dossier technique
	Ce template insère le contenu d'un template donné par fichierContenu.
	Exemple supports/alternateur/mes.html.twig

	Le code doit être mis dans un fichier twig dans le dossier src/Vue/supports/nom-support.
	Le template doit être un template twig car support/urls.twig qui définie les nom de dossiers
	pour différent type de fichiers (images pièces, assemblage, ...). Voir le fichier pour plus
	de précisions
#}

{% extends '11-base-avec-nav.html.twig' %}

{% block contenu %}
{% include 'supports/' ~ dossier ~ '/' ~ fichierContenu ~ '.html.twig' %}
{% endblock %}